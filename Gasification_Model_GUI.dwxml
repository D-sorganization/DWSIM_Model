        <InteractionParameter Compound1="Hydrogen" Compound2="Carbon monoxide" Value="0.0919" />
        <InteractionParameter Compound1="Hydrogen" Compound2="Methane" Value="0.0263" />
        <InteractionParameter Compound1="Hydrogen" Compound2="Carbon dioxide" Value="-0.1622" />
        <InteractionParameter Compound1="Nitrogen" Compound2="Carbon monoxide" Value="0.033" />
        <InteractionParameter Compound1="Nitrogen" Compound2="Oxygen" Value="-0.0159" />
        <InteractionParameter Compound1="Nitrogen" Compound2="Methane" Value="0.0289" />
        <InteractionParameter Compound1="Nitrogen" Compound2="Carbon dioxide" Value="-0.0222" />
        <InteractionParameter Compound1="Carbon monoxide" Compound2="Methane" Value="0.03" />
